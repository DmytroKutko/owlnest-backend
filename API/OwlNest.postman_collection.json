              }
            ],
            "url": "{{baseUrl}}/api/v1/profile/me/avatar"
          }
        }
      ]
    },
    {
      "name": "Media",
      "description": "Private Cloudflare R2-backed avatar and post-image lifecycle. Presigned URLs are temporary secrets; do not log or persist them.",
      "item": [
        {
          "name": "Create Avatar Upload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Avatar upload opportunity created', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('mediaId', body.mediaId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"purpose\": \"AVATAR\",\n  \"contentType\": \"image/webp\",\n  \"sizeBytes\": 524288\n}"
            },
            "url": "{{baseUrl}}/api/v1/media/uploads",
            "description": "Replace contentType and sizeBytes with the exact selected file metadata. Upload the bytes directly to body.upload.url using all body.upload.requiredHeaders before confirmation. Postman saves only mediaId and deliberately does not persist the capability URL or headers."
          }
        },
        {
          "name": "Create Post Image Upload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Post image upload opportunity created', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('postImageMediaId', body.mediaId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"purpose\": \"POST_IMAGE\",\n  \"contentType\": \"image/webp\",\n  \"sizeBytes\": 524288\n}"
            },
            "url": "{{baseUrl}}/api/v1/media/uploads",
            "description": "Upload bytes directly using body.upload.url and requiredHeaders. Only postImageMediaId is saved; signed URL and headers are never persisted."
          }
        },
        {
          "name": "Confirm Upload",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/media/{{mediaId}}/confirmation"
          }
        },
        {
          "name": "Confirm Post Image Upload",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}
            ],
            "url": "{{baseUrl}}/api/v1/media/{{postImageMediaId}}/confirmation"
          }
        },
        {
          "name": "Create Avatar Delivery",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/media/{{mediaId}}/delivery",
            "description": "Returns a short-lived bearer capability. Use it immediately and do not save it to collection or environment variables."
          }
        },
        {
          "name": "Create Post Image Delivery",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}
            ],
            "url": "{{baseUrl}}/api/v1/media/{{postImageMediaId}}/delivery",
            "description": "Call only after attachment. Use the short-lived returned GET URL immediately and never persist it."
          }
        },
        {
          "name": "Cancel Managed Media",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/media/{{mediaId}}",
            "description": "Cancels only owned pending or READY media. Active avatar media must first be removed or replaced through the Profile folder."
          }
        }
      ]
    },
    {
      "name": "Posts",
      "description": "Authenticated single-post CRUD, chronological comments, and idempotent interactions. Run Create Post first; it saves postId.",
      "item": [
        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Post created', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('postId', pm.response.json().id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"A quiet corner\",\n  \"description\": \"Found a place to slow down and breathe.\",\n  \"labels\": [\"Community Post\", \"Books\"],\n  \"media\": [\n    {\"type\": \"IMAGE\", \"url\": \"https://cdn.example.com/quiet-corner.jpg\"},\n    {\"type\": \"VIDEO\", \"url\": \"https://cdn.example.com/quiet-corner.mp4\"}\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/posts"
          }
        },
        {
          "name": "Create Post With Managed Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Managed-image post created', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('postId', pm.response.json().id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Post backed by private R2 media.\",\n  \"media\": [{\"type\": \"IMAGE\", \"mediaId\": \"{{postImageMediaId}}\"}]\n}"
            },
            "url": "{{baseUrl}}/api/v1/posts",
            "description": "Run Create Post Image Upload, direct PUT, and Confirm Post Image Upload first."
          }
        },
        {
          "name": "List Global Posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Global post page returned', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "  const cursor = pm.response.json().page.nextCursor;",
                  "  pm.collectionVariables.set('globalPostCursorQuery', cursor ? `&cursor=${cursor}` : '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts?limit=20{{globalPostCursorQuery}}"
          }
        },
        {
          "name": "Get Post",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}"
          }
        },
        {
          "name": "Replace Post",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated post retaining its managed image.\",\n  \"labels\": [],\n  \"media\": [{\"type\": \"IMAGE\", \"mediaId\": \"{{postImageMediaId}}\"}]\n}"
            },
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}"
          }
        },
        {
          "name": "Create Post Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Comment created', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('commentId', pm.response.json().id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"A thoughtful comment on this post.\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/comments"
          }
        },
        {
          "name": "List Post Comments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Comment page returned', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "  const cursor = pm.response.json().page.nextCursor;",
                  "  pm.collectionVariables.set('commentCursorQuery', cursor ? `&cursor=${cursor}` : '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/comments?limit=20{{commentCursorQuery}}"
          }
        },
        {
          "name": "Set Post Liked",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/likes"
          }
        },
        {
          "name": "Clear Post Liked",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/likes"
          }
        },
        {
          "name": "Set Post Bookmarked",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/bookmark"
          }
        },
        {
          "name": "Clear Post Bookmarked",
          "request": {
            "method": "DELETE",
