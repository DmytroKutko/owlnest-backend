{
  "info": {
    "_postman_id": "9740a8e4-6907-45c8-8c67-4a4fb9415ec0",
    "name": "OwlNest Local API",
    "description": "Local Keycloak and OwlNest Backend requests. Import and select the ignored OwlNest Local environment generated from .env. Flutter uses Authorization Code with PKCE.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "adminAccessToken",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "accountId",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requirementsByRequest = {",
          "  'Backend Health': ['baseUrl'],",
          "  'Keycloak Discovery': ['keycloakUrl', 'realm'],",
          "  'Get Admin Token': ['keycloakUrl', 'adminUsername', 'adminPassword'],",
          "  'Create Test User': ['keycloakUrl', 'realm', 'adminAccessToken', 'email', 'password', 'firstName', 'lastName'],",
          "  'Development Email-Password Login': ['keycloakUrl', 'realm', 'clientId', 'email', 'password'],",
          "  'Refresh Access Token': ['keycloakUrl', 'realm', 'clientId', 'refreshToken'],",
          "  'Complete or Replace Current Profile': ['baseUrl', 'accessToken'],",
          "  'Get Current Profile': ['baseUrl', 'accessToken'],",
          "  'Heartbeat': ['baseUrl', 'accessToken'],",
          "  'Get Public Profile': ['baseUrl', 'accessToken', 'accountId'],",
          "  'Create Post': ['baseUrl', 'accessToken'],",
          "  'Get Post': ['baseUrl', 'accessToken', 'postId'],",
          "  'Replace Post': ['baseUrl', 'accessToken', 'postId'],",
          "  'Delete Post': ['baseUrl', 'accessToken', 'postId'],",
          "  'Set Post Liked': ['baseUrl', 'accessToken', 'postId'],",
          "  'Clear Post Liked': ['baseUrl', 'accessToken', 'postId'],",
          "  'Set Post Bookmarked': ['baseUrl', 'accessToken', 'postId'],",
          "  'Clear Post Bookmarked': ['baseUrl', 'accessToken', 'postId'],",
          "  'Set Post Reposted': ['baseUrl', 'accessToken', 'postId'],",
          "  'Clear Post Reposted': ['baseUrl', 'accessToken', 'postId']",
          "};",
          "const required = requirementsByRequest[pm.info.requestName] || [];",
          "const missing = required.filter((key) => {",
          "  const value = pm.variables.get(key);",
          "  return typeof value !== 'string' || value.trim().length === 0;",
          "});",
          "if (missing.length > 0) {",
          "  throw new Error(`Missing Postman variables for ${pm.info.requestName}: ${missing.join(', ')}. Import and select API/OwlNest.local.postman_environment.json, then retry.`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Infrastructure",
      "item": [
        {
          "name": "Backend Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        },
        {
          "name": "Keycloak Discovery",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{keycloakUrl}}/realms/{{realm}}/.well-known/openid-configuration"
          }
        }
      ]
    },
    {
      "name": "Development User Setup",
      "description": "Development-only Keycloak Admin API helpers. Do not use these requests from Flutter.",
      "item": [
        {
          "name": "Get Admin Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin token issued', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('adminAccessToken', response.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "client_id",
                  "value": "admin-cli"
                },
                {
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "key": "username",
                  "value": "{{adminUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}"
                }
              ]
            },
            "url": "{{keycloakUrl}}/realms/master/protocol/openid-connect/token"
          }
        },
        {
          "name": "Create Test User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User created or already exists', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{email}}\",\n  \"email\": \"{{email}}\",\n  \"firstName\": \"{{firstName}}\",\n  \"lastName\": \"{{lastName}}\",\n  \"enabled\": true,\n  \"emailVerified\": false,\n  \"credentials\": [\n    {\n      \"type\": \"password\",\n      \"value\": \"{{password}}\",\n      \"temporary\": false\n    }\n  ]\n}"
            },
            "url": "{{keycloakUrl}}/admin/realms/{{realm}}/users"
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Development Email-Password Login",
          "description": "Development/Postman-only Direct Access Grant. Flutter uses Authorization Code with PKCE.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User tokens issued', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', response.access_token);",
                  "  pm.collectionVariables.set('refreshToken', response.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "client_id",
                  "value": "{{clientId}}"
                },
                {
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "key": "username",
                  "value": "{{email}}"
                },
                {
                  "key": "password",
                  "value": "{{password}}"
                },
                {
                  "key": "scope",
                  "value": "openid profile email"
                }
              ]
            },
            "url": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token"
          }
        },
        {
          "name": "Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Access token refreshed', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', response.access_token);",
                  "  pm.collectionVariables.set('refreshToken', response.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "client_id",
                  "value": "{{clientId}}"
                },
                {
                  "key": "grant_type",
                  "value": "refresh_token"
                },
                {
                  "key": "refresh_token",
                  "value": "{{refreshToken}}"
                }
              ]
            },
            "url": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Complete or Replace Current Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john.doe\",\n  \"displayName\": \"John Doe\",\n  \"bio\": \"Building OwlNest\",\n  \"birthDate\": \"1995-04-20\",\n  \"gender\": \"PREFER_NOT_TO_SAY\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/profile/me"
          }
        },
        {
          "name": "Get Current Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Current profile returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('accountId', pm.response.json().accountId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/profile/me"
          }
        },
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/profiles/{{accountId}}"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "description": "Authenticated single-post CRUD and idempotent interactions. Run Create Post first; it saves postId. Comments remain a client-side same-post #comments hook.",
      "item": [
        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Post created', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('postId', pm.response.json().id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"A quiet corner\",\n  \"description\": \"Found a place to slow down and breathe.\",\n  \"postType\": \"COMMUNITY\",\n  \"labels\": [\"Community Post\", \"Books\"],\n  \"media\": [\n    {\"type\": \"IMAGE\", \"url\": \"https://cdn.example.com/quiet-corner.jpg\"},\n    {\"type\": \"VIDEO\", \"url\": \"https://cdn.example.com/quiet-corner.mp4\"}\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/posts"
          }
        },
        {
          "name": "Get Post",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}"
          }
        },
        {
          "name": "Replace Post",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description-only post.\",\n  \"postType\": \"PERSONAL\",\n  \"labels\": [],\n  \"media\": []\n}"
            },
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}"
          }
        },
        {
          "name": "Set Post Liked",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/likes"
          }
        },
        {
          "name": "Clear Post Liked",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/likes"
          }
        },
        {
          "name": "Set Post Bookmarked",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/bookmark"
          }
        },
        {
          "name": "Clear Post Bookmarked",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/bookmark"
          }
        },
        {
          "name": "Set Post Reposted",
          "request": {
            "method": "PUT",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/repost"
          }
        },
        {
          "name": "Clear Post Reposted",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}/repost"
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text"}],
            "url": "{{baseUrl}}/api/v1/posts/{{postId}}"
          }
        }
      ]
    },
    {
      "name": "Presence",
      "item": [
        {
          "name": "Heartbeat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/presence/heartbeat"
          }
        }
      ]
    }
  ]
}
