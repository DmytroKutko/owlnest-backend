# Copy this file to .env and keep the local file uncommitted.
POSTGRES_DB=owlnest
POSTGRES_USER=owlnest
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_PORT=5432
REDIS_PORT=6379
SERVER_PORT=8080
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-local-admin-password
KEYCLOAK_TEST_USER_EMAIL=dev.user@owlnest.local
KEYCLOAK_TEST_USER_PASSWORD=replace-with-a-local-test-password
KEYCLOAK_TEST_USER_FIRST_NAME=John
KEYCLOAK_TEST_USER_LAST_NAME=Doe
KEYCLOAK_SEED_USER_PASSWORD=replace-with-a-local-seed-password

# Cloudflare R2 remains disabled until real private-bucket credentials are supplied.
R2_ENABLED=false
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ENDPOINT=https://replace-with-cloudflare-account-id.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET_NAME=replace-with-private-bucket-name
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_UPLOAD_URL_TTL=15m
R2_READ_URL_TTL=5m
R2_CONNECTION_ACQUISITION_TIMEOUT=1s
R2_CONNECT_TIMEOUT=2s
R2_READ_TIMEOUT=3s
R2_API_CALL_ATTEMPT_TIMEOUT=4s
R2_API_CALL_TIMEOUT=12s
R2_MAX_ATTEMPTS=3
MEDIA_CLEANUP_FIXED_DELAY=1m
MEDIA_CLEANUP_INITIAL_DELAY=30s
